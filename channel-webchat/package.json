{
  "name": "@blue-tanuki/channel-webchat",
  "version": "0.0.2",
  "private": true,
  "description": "WebChat channel adapter (HTTP inbound + WebSocket outbound, ticket-auth)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@blue-tanuki/protocol": "workspace:*",
    "@blue-tanuki/channel-base": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  }
}

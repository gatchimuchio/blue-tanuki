{
  "name": "@blue-tanuki/channel-telegram",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Telegram Bot API channel adapter for BLUE-TANUKI v0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --passWithNoTests"
  },
  "dependencies": {
    "@blue-tanuki/protocol": "workspace:*",
    "@blue-tanuki/channel-base": "workspace:*"
  }
}

{
  "name": "@blue-tanuki/channel-slack",
  "version": "0.0.2",
  "private": true,
  "license": "MIT",
  "description": "Slack channel adapter (Bolt + Socket Mode, typed delivery errors)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --passWithNoTests"
  },
  "dependencies": {
    "@blue-tanuki/protocol": "workspace:*",
    "@blue-tanuki/channel-base": "workspace:*",
    "@slack/bolt": "^3.22.0"
  }
}

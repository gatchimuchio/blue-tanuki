{
  "name": "@blue-tanuki/core",
  "version": "1.0.0-rc.1",
  "kind": "core",
  "entry": "./dist/index.js",
  "exports": {
    "default": "Executor",
    "tools": "registerBuiltinTools",
    "llm_registry": "LLMRegistry",
    "llm_stub": "StubBackend",
    "llm_anthropic": "AnthropicBackend",
    "llm_openai_compatible": "OpenAICompatibleBackend"
  },
  "permissions": [
    "fs:append:session_dir",
    "fs:read:session_dir",
    "fs:write:session_dir",
    "secrets:ANTHROPIC_API_KEY",
    "secrets:OPENAI_API_KEY",
    "secrets:OPENAI_COMPAT_API_KEY",
    "secrets:LLM_API_KEY",
    "secrets:LLM_PROVIDERS_JSON",
    "secrets:OPENAI_COMPAT_HEADERS_JSON",
    "secrets:LLM_HEADERS_JSON",
    "network:llm-provider",
    "tool:echo",
    "tool:file.search",
    "tool:file.write",
    "tool:file.edit",
    "tool:http.fetch",
    "tool:web.search",
    "tool:github.read",
    "tool:github.write",
    "tool:gmail.read",
    "tool:google.calendar.read",
    "tool:google.drive.read",
    "tool:gmail.write",
    "tool:google.calendar.write",
    "tool:google.drive.write",
    "tool:browser.read",
    "tool:browser.snapshot",
    "tool:browser.automation",
    "tool:shell.exec",
    "fs:read",
    "fs:write",
    "shell:exec",
    "network:http",
    "browser:snapshot",
    "browser:act",
    "network:github.com",
    "network:googleapis.com",
    "secrets:GITHUB_TOKEN",
    "secrets:GOOGLE_ACCESS_TOKEN",
    "secrets:GMAIL_ACCESS_TOKEN",
    "secrets:GOOGLE_CALENDAR_ACCESS_TOKEN",
    "secrets:GOOGLE_DRIVE_ACCESS_TOKEN",
    "google:gmail.read",
    "google:calendar.read",
    "google:drive.read",
    "google:gmail.write",
    "google:calendar.write",
    "google:drive.write",
    "external:send",
    "email:send",
    "github:issue.write",
    "github:pr.write",
    "github:comment.write"
  ],
  "description": "BLUE-TANUKI executor: provider-neutral LLM backend registry, permission-gated tool registry, OutboundDispatcher integration, SessionStore (memory + json file). Network/secrets permissions apply only when a non-stub LLM or network tool is configured; fs permissions apply only when sessions or fs tools are allowed."
}

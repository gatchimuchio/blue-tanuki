{
  "name": "@blue-tanuki/operator-writing",
  "version": "1.0.0-rc.1",
  "private": true,
  "license": "MIT",
  "description": "First-party Writing Operator surface for BLUE-TANUKI v1.0 RC",
  "type": "module",
  "main": "./dist/index.js",

# Copy to /etc/blue-tanuki/blue-tanuki.env and chmod 600.
# Do not commit real tokens.

WEBCHAT_TOKEN=replace-with-long-random-inbound-token
WEBCHAT_RESUME_TOKEN=replace-with-long-random-resume-token
BLUE_TANUKI_SETTINGS_TOKEN=replace-with-long-random-settings-token

WEBCHAT_HOST=127.0.0.1
WEBCHAT_PORT=8787

LLM_BACKEND=stub
LLM_DEFAULT_BACKEND=
LLM_PROVIDERS_JSON=
LLM_ENDPOINT=
LLM_MODEL=
LLM_API_KEY=
LLM_HEADERS_JSON=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_COMPAT_ENDPOINT=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_API_KEY=

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=

BLUE_TANUKI_AUDIT_DIR=/var/lib/blue-tanuki/audit
BLUE_TANUKI_SESSION_DIR=/var/lib/blue-tanuki/sessions
BLUE_TANUKI_LOG_LEVEL=info
BLUE_TANUKI_LOG_FORMAT=text
BLUE_TANUKI_HTTP_ALLOWLIST=

# Resident local-app default. Set ask_every_time for strict demos/audits/shared machines.
BLUE_TANUKI_APPROVAL_MODE=full_access
BLUE_TANUKI_APPROVALS_FILE=/var/lib/blue-tanuki/approval-grants.json

# Telegram v0.1 channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_INTERVAL_MS=1500
TELEGRAM_POLL_TIMEOUT_SEC=25

# v0.1 Daily Brief scheduled-message smoke. Real Gmail/GCal/Drive brief is v0.2+.
BLUE_TANUKI_DAILY_BRIEF_ENABLED=0
BLUE_TANUKI_DAILY_BRIEF_CHANNEL=telegram
BLUE_TANUKI_DAILY_BRIEF_TARGET=
BLUE_TANUKI_DAILY_BRIEF_TIME=07:00
BLUE_TANUKI_DAILY_BRIEF_CONTENT=Daily Brief: scheduled smoke from BLUE-TANUKI v0.1
